<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Postulation</title>
</head>
<body>
<link rel="stylesheet" href="../../assets/css/style.css">
<header class="header-minimal">
        <a href="/recherche/fiche?id_cible={{ id_cible }}&type=3&page=1" class="back-button" title="Retour à la recherche">
            <img src="../../assets/images/back-arrow.png" alt="Retour">
        </a>
    </header>
    {% if result == "null" %}
    <main class="container-offre">
        <section class="card form-card">
            <form id="postform" method="post" enctype="multipart/form-data">
                <div class="form-grid">
                    <div class="field">
                        <label for="cv">Curriculum Vitae (CV)</label>
                        <input type="file" id="postfile" name="CV" accept="application/pdf" required>
                        <span class="hint">Format PDF de préférence</span>
                    </div>
                    <div class="field">
                        <label for="lm">Lettre de motivation</label>
                        <textarea class="post-textarea" type="text" id="lm" name="LM"> </textarea>
                        <span class="hint">Optionnel</span>
                    </div>
                </div>

                <div class="actions">
                    <button type="submit" class="btn-primary">Envoyer ma candidature</button>
                </div>
            </form>
        </section>
    </main>
    {% else %}
        <main class="container-offre">
            <section class="card form-card">
                <span class="title" >{{ result }}</span>
            </section>
        </main>
    {% endif %}

</body>
</html>