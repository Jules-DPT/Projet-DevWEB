{% extends "base.html.twig" %}


<div class="liquid-form-center">

    <div class="liquid_box">
        <div class="margin_div">
            <form class="form-center">
                <label>
                    <input type="search" id="Recherche" name="text&quot;" placeholder="Recherchez ici !" class="liquid_box_mini">
                    <input type="submit" id="Recherche_btn" value="Rechercher" class="liquid_box_mini">
                </label>
            </form>
            <br>
            <div class="conteneur">
                <label class="liquid_box_mini" ><input type="radio" id="étudiants" name="type" value="utilisateur" > Comptes</label>
                <label class="liquid_box_mini" ><input type="radio" id="offres" name="type" value="posts" checked> Offres</label>
                <label class="liquid_box_mini" ><input type="radio" id="entreprises" name="type" value="entreprise"> Fiches entreprises</label>
            </div>

        </div>
        <div class="conteneur_offres" >
            <div id="affichage_posts" class="conteneurgrid">
                {% block affichage %}
                    <div class="box-simple">
                        <p></p>
                        <P></P>
                        <P></P>
                        <p></p>
                    </div>
                {% endblock %}
            </div>

        </div>
    </div>

    {% extends "Pagination.html.twig" %}
</div>
