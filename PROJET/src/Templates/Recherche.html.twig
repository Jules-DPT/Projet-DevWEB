
<!DOCTYPE html>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<html lang="fr">

<head>
    <link rel="stylesheet" href="../../assets/css/recherche.css">
    <link rel="stylesheet" href="../../assets/css/style.css">
    <meta charset="UTF-8">
    <title>Accueil</title>
</head>


<body>
{% block head %}
    {% include "base.html.twig" with{"path":path} %}
{% endblock %}
<br>
<br>
{% block body %}
<main id="main" class="container page search">
<div class="page-head">
      <h1>Rechercher une offre</h1>
      <p class="muted">La vérité je sais pas quoi écrire c'est pas mon job ça</p>
    </div>

    <section class="card form-card" aria-label="Barre de recherche offre">
      <form action="?= strtok($_SERVER['REQUEST_URI'], '?') ?>" method="get">
        
        <div class="field">
          <label for="rechercher">Rechercher</label>
          <input id="Recherche" name="recherche" type="search" placeholder="ex: Stage ingénieur..." />
        </div>
        <div class="actions">
          <div class="radio-group">
            {% if type==1 %}
                {% if (role=="PILOTE" or role=="ADMIN") %}
                    <input type="radio" id="étudiants" name="type" value=1>
                    <label for="étudiants">Comptes</label>
                {% endif %}
                <input type="radio" id="offres" name="type" value=3 checked>
                <label for="offres">Offres</label>
                <input type="radio" id="entreprises" name="type" value=2>
                <label for="entreprises">Fiches entreprises</label>
            {% endif %}
            {% if type==2 %}
                {% if (role=="PILOTE" or role=="ADMIN") %}
                    <input type="radio" id="étudiants" name="type" value=1>
                    <label for="étudiants">Comptes</label>
                {% endif %}
                <input type="radio" id="offres" name="type" value=3 checked>
                <label for="offres">Offres</label>
                <input type="radio" id="entreprises" name="type" value=2>
                <label for="entreprises">Fiches entreprises</label>
            {% endif %}
            {% if type==3 %}
                {% if (role=="PILOTE" or role=="ADMIN") %}
                    <input type="radio" id="étudiants" name="type" value=1>
                    <label for="étudiants">Comptes</label>
                {% endif %}
                <input type="radio" id="offres" name="type" value=3 checked>
                <label for="offres">Offres</label>
                <input type="radio" id="entreprises" name="type" value=2>
                <label for="entreprises">Fiches entreprises</label>
            {% endif %}
          </div>
          <button type="reset" class="btn-primary">Effacer</button>
          <button class="btn-primary" type="submit" id="Recherche_btn" value="Rechercher">Rechercher</button>
        </div>
      </form>
    </section>
        <div class="conteneur_offres" >
            {% if res is null %}
                <br> <br> <br>
                <p style="font-size: 20px"> Oups il n'y a pas grand chose ici...</p>
                <br> <br>  <br>
            {% endif %}
            <div id="affichage_posts" class="conteneurgrid">
                {% if (type==1) %}
                    {% include 'Comptes.html.twig' with {'contenant':contenant} %}
                {% endif %}
                {% if (type==2) %}
                    {% include 'Entreprises.html.twig' with {'contenant':contenant} %}
                {% endif %}
                {% if (type==3) %}
                    {% include 'Posts.html.twig' with {'contenant':contenant,'check':check} %}
                {% endif %}
            </div>

        </div>
        <script src="../../assets/js/recherche.js"></script>
        {% include 'Pagination.html.twig' with {'totalPages':totalPages , 'path':path,'page':page} %}
    </div>



</div>
</main>
{% endblock %}
</body>
</html>