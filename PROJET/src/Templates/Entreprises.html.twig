{% block affichage %}
    {% for entreprise in contenant %}

        <div class="offres">
            <span><img src="../../Files/Entreprises/logo/{{ entreprise.file }}" alt="PNG"></span>
            <span class="offres title">{{ entreprise.nom }}</span>
            <span class="offres desc">{{ entreprise.description }}</span>
            <span class="lieu">{{ entreprise.ville }}</span>
            <div class="bottom">

                <span class="date">note: {{  entreprise.note!= 0 ? entreprise.note : '...' }} </span> <span class="nb-post">Posts :{{ entreprise.nbposts }}</span>
            </div>
        </div>

    {% endfor %}
{% endblock %}