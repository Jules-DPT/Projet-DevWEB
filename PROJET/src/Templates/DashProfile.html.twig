{% block affichage %}
    <form>

                <div class="grid-2">
                    <div class="field">
                        <label for="nom">Nom</label>
                        <input type="text" id="nom" value="Dupont">
                    </div>

                    <div>
                        <label for="prenom">Prénom</label>
                        <input type="text" id="prenom" value="Marie">
                    </div>
                </div>

                <div class="grid-2">
                    <div class="field">
                        <label for="email">Email</label>
                        <input type="email" id="email" value="marie.dupont@email.com">
                    </div>

                    <div>
                        <label for="telephone">Téléphone</label>
                        <input type="text" id="telephone" placeholder="Votre numéro">
                    </div>
                </div>

                <div class="grid-2">
                    <div class="field">
                        <label for="campus">Campus</label>
                        <input type="text" id="campus" value="La Rochelle">
                    </div>

                    <div>
                        <label for="promotion">Promotion suivie</label>
                        <input type="text" id="promotion" value="A2 CPI Informatique">
                    </div>
                </div>

                <div class="field">
                    <label for="role">Fonction</label>
                    <input type="text" id="role" value="Pilote pédagogique">
                </div>

                <div class="field">
                    <label for="description">Présentation</label>
                    <textarea class="board-textarea" id="description" rows="5">J’accompagne les étudiants dans leur suivi pédagogique, leurs candidatures et leur progression professionnelle.</textarea>
                </div>

                <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>
    </form>
{% endblock %}