{% block affichage %}
    <form>

                <div class="grid-2">
                    <div class="field">
                        <label for="nom">Nom</label>
                        <input type="text" id="nom" value={{ compte.nom }}>
                    </div>

                    <div>
                        <label for="prenom">Prénom</label>
                        <input type="text" id="prenom" value={{ compte.prenom }}>
                    </div>
                </div>
                 <br>
                <div class="grid-2">
                    <div class="field">
                        <label for="email">Email</label>
                        <input type="email" id="email" value={{ compte.email }}>
                    </div>

                    <div>
                        <label for="telephone">Téléphone</label>
                        <input type="text" id="telephone" placeholder={{ compte.telephone }}>
                    </div>
                </div>
        <br>

                <div class="field">
                    <label for="role">Fonction</label>
                    <input type="text" id="role" value={{ compte.promo }}>
                </div>

    </form>
{% endblock %}