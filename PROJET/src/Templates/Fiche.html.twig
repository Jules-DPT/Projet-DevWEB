<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Fiche</title>
</head>
<body>
        <a href="/recherche?type={{ type }}"><input></a>
        {% if contenant==null %}
            <h1> Oups il n'y a pas grand chose ici...</h1>
        {% else %}
            {% if type==1 %}
                {% include 'Compte.html.twig' with {'compte':contenant} %}
            {% endif %}
            {% if type==2 %}
                {% include 'Entreprise.html.twig' with {'entreprise':contenant} %}
                {% include 'Commentaires.html.twig' with {'commentaires':commentaires, 'totalPages':totalPages , 'path':path,'page':page,'role':role} %}
            {% endif %}
            {% if type==3 %}
                {% include 'Post.html.twig' with {'post':contenant} %}
                {% include 'Commentaires.html.twig' with {'commentaires':commentaires, 'totalPages':totalPages , 'path':path,'page':page,'role':role} %}
            {% endif %}
        {% endif %}
</body>
</html>